{
  "mcpServers": {
    "shopify-dev-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@shopify/dev-mcp@latest"
      ]
    },
    "shopify-admin-api": {
      "command": "npm",
      "args": [
        "run",
        "mcp:admin",
        "--silent"
      ],
      "env": {
        "SHOPIFY_STORE_DOMAIN": "your-store.myshopify.com",
        "SHOPIFY_ADMIN_API_TOKEN": "${SHOPIFY_ADMIN_API_TOKEN}",
        "SHOPIFY_ADMIN_API_VERSION": "2026-07"
      }
    }
  }
}
