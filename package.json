{
  "name": "hazify-shopify-agent",
  "version": "0.1.0",
  "description": "A secure local Shopify AI agent workspace for Codex, Claude Code, and OpenCode.",
  "type": "module",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/jordyhaasje/hazify-shopify-agent.git"
  },
  "bin": {
    "hazify-shopify-agent": "./bin/cli.js"
  },
  "files": [
    ".codex/",
    ".env.example",
    ".mcp.json",
    "AGENTS.md",
    "CLAUDE.md",
    "LICENSE",
    "README.md",
    "START_HERE.md",
    "app-template/",
    "bin/",
    "configs/",
    "dist/",
    "opencode.json",
    "prompts/",
    "src/",
    "theme/.gitkeep",
    "tsconfig.json",
    "workflows/"
  ],
  "scripts": {
    "start": "tsx src/cli.ts launch",
    "build": "tsc",
    "prepack": "npm run build",
    "launch": "tsx src/cli.ts launch",
    "setup": "tsx src/cli.ts setup",
    "setup:agent": "tsx src/cli.ts setup --agent --clients all",
    "doctor": "tsx src/cli.ts doctor",
    "configure": "tsx src/cli.ts configure",
    "auth": "tsx src/cli.ts auth",
    "auth:advanced": "tsx src/cli.ts auth --advanced",
    "data:connect": "tsx src/cli.ts auth --data-agent",
    "data:legacy-store-auth": "tsx src/cli.ts data legacy-store-auth",
    "data:verify": "tsx src/cli.ts data verify",
    "mcp:admin": "tsx src/mcp/adminApiServer.ts",
    "theme:list": "tsx src/cli.ts theme list",
    "theme:pull": "tsx src/cli.ts theme pull",
    "theme:check": "tsx src/cli.ts theme check",
    "theme:dev": "tsx src/cli.ts theme dev"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.6",
    "inquirer": "^14.0.2",
    "open": "^11.0.0",
    "ora": "^9.4.1",
    "tsx": "^4.23.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
